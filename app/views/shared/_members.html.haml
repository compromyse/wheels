%section
  %h2.text-2xl.font-bold.text-gray-900.mb-6 Members

  = form_with url: location_path, method: :get, class: "flex gap-3 mb-6" do |f|
    - params.permit(:tab).each do |key, val|
      %input{type: "hidden", name: key, value: val}
    = f.text_field :member_query, value: params[:member_query], placeholder: "Search by name or email",
        class: "flex-1 px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
    = f.submit "Search", class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors"

  - if search_results&.any?
    .mb-8.space-y-2
      %p.text-lg.font-semibold.text-gray-700.mb-2 Add a member
      - search_results.each do |user|
        .flex.items-center.justify-between.px-6.py-4.border-2.border-gray-400
          .space-y-0.5
            %p.text-xl.font-bold.text-gray-900= user.name
            %p.text-lg.text-gray-500= user.email
          = form_with url: members_create_path, method: :post, class: "flex items-center gap-3" do |f|
            = f.hidden_field :user_id, value: user.id
            = f.select :role, roles.map { |r| [r.capitalize, r] },
                {}, class: "px-3 py-2 text-lg border-2 border-gray-400 bg-white"
            = f.submit "Add", class: "px-4 py-2 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors"
  - elsif params[:member_query].present?
    %p.text-lg.text-gray-500.mb-6 No users found matching that search.

  - if members.any?
    .space-y-2
      %p.text-lg.font-semibold.text-gray-700.mb-2 Current members
      - members.each do |membership|
        .flex.items-center.justify-between.px-6.py-4.border-2.border-gray-900
          .space-y-0.5
            %p.text-xl.font-bold.text-gray-900= membership.user.name
            %p.text-lg.text-gray-500= membership.user.email
          .flex.items-center.gap-3
            = form_with url: member_update_path.call(membership), method: :patch, class: "flex items-center gap-2" do |f|
              = f.select :role, roles.map { |r| [r.capitalize, r] }, { selected: membership.role },
                  class: "px-3 py-2 text-lg border-2 border-gray-400 bg-white",
                  onchange: "this.form.requestSubmit(); this.nextElementSibling.classList.remove('hidden')"
              %span.hidden.text-gray-400{"aria-hidden": "true"}
                %svg{xmlns: "http://www.w3.org/2000/svg", width: "18", height: "18", viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2", class: "animate-spin"}
                  %circle{cx: "12", cy: "12", r: "10", "stroke-opacity": "0.25"}
                  %path{d: "M12 2a10 10 0 0 1 10 10"}
            = button_to "Remove", member_destroy_path.call(membership), method: :delete,
                data: { turbo_confirm: "Remove #{membership.user.name}?" },
                class: "px-4 py-2 text-lg font-medium text-red-700 underline bg-transparent border-0 cursor-pointer"
  - else
    %p.text-xl.text-gray-500 No members yet.
