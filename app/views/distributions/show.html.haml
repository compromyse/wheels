- content_for :title, @distribution.name
.flex.items-center.justify-between.mb-8
  %h1.text-3xl.font-bold.text-gray-900= @distribution.name
  = link_to "Request Bikes", new_distribution_bike_request_path(@distribution),
      class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 transition-colors"

= render "bike_requests/list", active_tab: @tab, bike_requests: @bike_requests, pagy: @pagy, production_view: false
