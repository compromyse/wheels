- content_for :title, "Log in"
.max-w-md.mx-auto.mt-16
  %h1.text-4xl.font-bold.text-gray-900.mb-10 Log in to Wheels
  = form_with url: login_path, class: "space-y-6" do |f|
    .space-y-2
      = f.label :email, "Email address", class: "block text-xl font-medium text-gray-900"
      = f.email_field :email, autocomplete: "email", autofocus: true,
          class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
    .space-y-2
      = f.label :password, "Password", class: "block text-xl font-medium text-gray-900"
      = f.password_field :password, autocomplete: "current-password",
          class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
    = f.submit "Log in", class: "w-full py-4 text-xl font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors"
