- content_for :title, "Distribution Centers"
.flex.items-center.justify-between.mb-8
  %h1.text-3xl.font-bold.text-gray-900 Distribution Centers
  = link_to "Add", new_admin_distribution_center_path, class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 transition-colors"

- if @distribution_centers.any?
  .space-y-2
    - @distribution_centers.each do |dc|
      .flex.items-center.justify-between.px-6.py-5.border-2.border-gray-900
        %span.text-2xl.font-bold.text-gray-900= dc.name
        = button_to "Remove", admin_distribution_center_path(dc), method: :delete,
            data: { turbo_confirm: "Remove #{dc.name}?" },
            class: "px-4 py-2 text-lg font-medium text-red-700 underline bg-transparent border-0 cursor-pointer"
- else
  %p.text-xl.text-gray-500 No distribution centers yet.
