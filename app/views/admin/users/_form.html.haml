= form_with model: [:admin, user], class: "space-y-8 max-w-lg" do |f|
  .space-y-2
    = f.label :name, "Full name", class: "block text-xl font-medium text-gray-900"
    = f.text_field :name, autofocus: true,
        class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
    - user.errors[:name].each do |msg|
      %p.text-lg.text-red-700= msg

  .space-y-2
    = f.label :email, "Email address", class: "block text-xl font-medium text-gray-900"
    = f.email_field :email,
        class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
    - user.errors[:email].each do |msg|
      %p.text-lg.text-red-700= msg

  .space-y-2
    = f.label :password, (user.persisted? ? "New password (leave blank to keep current)" : "Password"),
        class: "block text-xl font-medium text-gray-900"
    = f.password_field :password,
        class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"

  - unless user.persisted?
    .space-y-2
      = f.label :password_confirmation, "Confirm password", class: "block text-xl font-medium text-gray-900"
      = f.password_field :password_confirmation,
          class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"

  .flex.items-center.gap-3
    = f.check_box :superadmin, class: "w-6 h-6 border-2 border-gray-400"
    = f.label :superadmin, "Superadmin", class: "text-xl font-medium text-gray-900"

  - unless user.superadmin?
    - if productions.any?
      %fieldset.space-y-3
        %legend.text-xl.font-semibold.text-gray-900.mb-3 Production Access
        - productions.each do |production|
          - assigned = user_productions_map[production.id]
          .flex.items-center.gap-4.py-3.border-b.border-gray-200
            %input{type: "checkbox", name: "production_access_enabled[#{production.id}]",
                id: "production_#{production.id}", value: "1", checked: assigned.present?,
                class: "w-6 h-6 border-2 border-gray-400"}
            %label{for: "production_#{production.id}", class: "text-xl text-gray-900 flex-1"}= production.name
            %select{name: "production_access_role[#{production.id}]",
                class: "px-3 py-2 text-lg border-2 border-gray-400 bg-white"}
              - UserProduction::ROLES.each do |role|
                %option{value: role, selected: (assigned&.dig(:role) || "volunteer") == role}= role.capitalize

    - if distributions.any?
      %fieldset.space-y-3
        %legend.text-xl.font-semibold.text-gray-900.mb-3 Distribution Access
        - distributions.each do |dist|
          - assigned = user_distributions_map[dist.id]
          .flex.items-center.gap-4.py-3.border-b.border-gray-200
            %input{type: "checkbox", name: "distribution_access_enabled[#{dist.id}]",
                id: "dist_#{dist.id}", value: "1", checked: assigned.present?,
                class: "w-6 h-6 border-2 border-gray-400"}
            %label{for: "dist_#{dist.id}", class: "text-xl text-gray-900 flex-1"}= dist.name
            %select{name: "distribution_access_role[#{dist.id}]",
                class: "px-3 py-2 text-lg border-2 border-gray-400 bg-white"}
              - UserDistribution::ROLES.each do |role|
                %option{value: role, selected: (assigned&.dig(:role) || "volunteer") == role}= role.capitalize

  .flex.gap-4
    = f.submit (user.persisted? ? "Save Changes" : "Add User"),
        class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors"
    = link_to "Cancel", admin_users_path, class: "px-6 py-3 text-lg font-medium text-gray-900 underline"
