- content_for :title, "Productions"
.flex.items-center.justify-between.mb-8
  %h1.text-3xl.font-bold.text-gray-900 Productions
  = link_to "Add Production", new_admin_production_path, class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 transition-colors"

- if @productions.any?
  .space-y-2
    - @productions.each do |production|
      .flex.items-center.justify-between.px-6.py-5.border-2.border-gray-900
        %span.text-2xl.font-bold.text-gray-900= production.name
        = button_to "Remove", admin_production_path(production), method: :delete,
            data: { turbo_confirm: "Remove #{production.name}?" },
            class: "px-4 py-2 text-lg font-medium text-red-700 underline bg-transparent border-0 cursor-pointer"
- else
  %p.text-xl.text-gray-500 No productions yet.
