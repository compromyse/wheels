- content_for :title, "Distributions"
.flex.items-center.justify-between.mb-8
  %h1.text-3xl.font-bold.text-gray-900 Distributions
  = link_to "Add", new_admin_distribution_path, class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 transition-colors"

- if @distributions.any?
  .space-y-2
    - @distributions.each do |dist|
      .flex.items-center.justify-between.px-6.py-5.border-2.border-gray-900
        .space-y-1
          %p.text-2xl.font-bold.text-gray-900= dist.name
          %p.text-lg.text-gray-500= dist.address.presence || "No address"
        .flex.items-center.gap-6.shrink-0
          = link_to "Edit", edit_admin_distribution_path(dist), class: "px-4 py-2 text-lg font-medium text-gray-900 underline"
          = button_to "Remove", admin_distribution_path(dist), method: :delete,
              data: { turbo_confirm: "Remove #{dist.name}?" },
              class: "px-4 py-2 text-lg font-medium text-red-700 underline bg-transparent border-0 cursor-pointer"
- else
  %p.text-xl.text-gray-500 No distributions yet.
