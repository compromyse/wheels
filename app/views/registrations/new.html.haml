- content_for :title, "Sign up"
.max-w-md.mx-auto.mt-16
  %h1.text-4xl.font-bold.text-gray-900.mb-10 Create an account
  = form_with model: @user, url: signup_path, class: "space-y-6" do |f|
    .space-y-2
      = f.label :name, "Full name", class: "block text-xl font-medium text-gray-900"
      = f.text_field :name, autofocus: true,
          class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @user.errors[:name].each do |msg|
        %p.text-lg.text-red-700= msg
    .space-y-2
      = f.label :email, "Email address", class: "block text-xl font-medium text-gray-900"
      = f.email_field :email, autocomplete: "email",
          class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @user.errors[:email].each do |msg|
        %p.text-lg.text-red-700= msg
    .space-y-2
      = f.label :password, "Password", class: "block text-xl font-medium text-gray-900"
      = f.password_field :password, autocomplete: "new-password",
          class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @user.errors[:password].each do |msg|
        %p.text-lg.text-red-700= msg
    .space-y-2
      = f.label :password_confirmation, "Confirm password", class: "block text-xl font-medium text-gray-900"
      = f.password_field :password_confirmation, autocomplete: "new-password",
          class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
    = f.submit "Create account", class: "w-full py-4 text-xl font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors"
  %p.mt-6.text-lg.text-gray-600
    Already have an account?
    = link_to "Log in", login_path, class: "font-medium text-gray-900 underline"
