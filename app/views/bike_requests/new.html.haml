- content_for :title, "Request Bikes"
.max-w-4xl
  %h1.text-3xl.font-bold.text-gray-900.mb-8 Request Bikes

  = form_with model: [@distribution, @bike_request], class: "space-y-8" do |f|
    .space-y-2
      = f.label :phone, "Phone number", class: "block text-xl font-medium text-gray-900"
      = f.telephone_field :phone, placeholder: "10 digits, no hyphens", class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:phone].each do |msg|
        %p.text-lg.text-red-700= msg

    .space-y-2
      = f.label :requestor_name, "Requestor name", class: "block text-xl font-medium text-gray-900"
      = f.text_field :requestor_name, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:requestor_name].each do |msg|
        %p.text-lg.text-red-700= msg

    .space-y-2
      = f.label :due_date, "Due date", class: "block text-xl font-medium text-gray-900"
      = f.date_field :due_date, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:due_date].each do |msg|
        %p.text-lg.text-red-700= msg

    %div
      %p.text-xl.font-semibold.text-gray-900.mb-3 Bikes
      .overflow-x-auto
        %table.w-full.border-collapse
          %thead
            %tr.border-b-2.border-gray-900
              %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-900 Name
              %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-900 Type
              %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-900 Age
              %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-900 Height
              %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-900 Notes
          %tbody#bikes-tbody
            = f.fields_for :bikes do |bf|
              = render "bike_form_row", bf: bf
      %button.mt-3.px-4.py-2.text-lg.font-medium.text-gray-900.border-2.border-gray-400.hover:border-gray-900.transition-colors{type: "button", onclick: "addBikeRow()"} + Add bike

    .flex.gap-4
      = f.submit "Submit Request", class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors"
      = link_to "Cancel", tickets_distribution_path(@distribution), class: "px-6 py-3 text-lg font-medium text-gray-900 underline"

  :javascript
    var bikeRowIndex = 1;
    function addBikeRow() {
      var tbody = document.getElementById('bikes-tbody');
      var html = document.getElementById('bike-row-template').innerHTML
        .replace(/NEW_INDEX/g, bikeRowIndex++);
      var tr = document.createElement('tr');
      tr.innerHTML = html;
      tbody.appendChild(tr);
    }

%template#bike-row-template
  %td.px-3.py-2
    %input.w-full.px-2.py-1.text-lg.border-2.border-gray-400.focus:border-gray-900.focus:outline-none{type: "text", name: "bike_request[bikes_attributes][NEW_INDEX][name]", placeholder: "optional"}
  %td.px-3.py-2
    %select.px-2.py-1.text-lg.border-2.border-gray-400.bg-white{name: "bike_request[bikes_attributes][NEW_INDEX][bike_type]"}
      %option{value: "any"} Any
      %option{value: "male"} Male
      %option{value: "female"} Female
      %option{value: "kid"} Kid
  %td.px-3.py-2
    %input.w-20.px-2.py-1.text-lg.border-2.border-gray-400.focus:border-gray-900.focus:outline-none{type: "number", name: "bike_request[bikes_attributes][NEW_INDEX][age]", min: "1", max: "120"}
  %td.px-3.py-2
    %input.w-28.px-2.py-1.text-lg.border-2.border-gray-400.focus:border-gray-900.focus:outline-none{type: "text", name: "bike_request[bikes_attributes][NEW_INDEX][height]", placeholder: "5'4\""}
  %td.px-3.py-2
    %input.w-full.px-2.py-1.text-lg.border-2.border-gray-400.focus:border-gray-900.focus:outline-none{type: "text", name: "bike_request[bikes_attributes][NEW_INDEX][notes]"}
