- content_for :title, "Request Bikes"
.max-w-lg.mx-auto
  %h1.text-3xl.font-bold.text-gray-900.mb-8 Request Bikes

  = form_with model: [@distribution_center, @bike_request], class: "space-y-8" do |f|
    .space-y-2
      = f.label :phone, "Phone number", class: "block text-xl font-medium text-gray-900"
      = f.telephone_field :phone, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:phone].each do |msg|
        %p.text-lg.text-red-700= msg

    .space-y-2
      = f.label :requestor_name, "Requestor name", class: "block text-xl font-medium text-gray-900"
      = f.text_field :requestor_name, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:requestor_name].each do |msg|
        %p.text-lg.text-red-700= msg

    .space-y-2
      = f.label :due_date, "Due date", class: "block text-xl font-medium text-gray-900"
      = f.date_field :due_date, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:due_date].each do |msg|
        %p.text-lg.text-red-700= msg

    %hr.border-gray-200

    %p.text-sm.font-semibold.text-gray-500.uppercase.tracking-widest Person Details

    .space-y-2
      = f.label :recipient_name, "Name (if known)", class: "block text-xl font-medium text-gray-900"
      = f.text_field :recipient_name, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"

    .space-y-2
      = f.label :bike_type, "Bike type", class: "block text-xl font-medium text-gray-900"
      = f.select :bike_type, [["Male", "male"], ["Female", "female"], ["Kid", "kid"]], { include_blank: "Select..." }, class: "w-full px-3 py-2 text-lg border-2 border-gray-400 bg-white focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:bike_type].each do |msg|
        %p.text-lg.text-red-700= msg

    .space-y-2
      = f.label :age, "Age", class: "block text-xl font-medium text-gray-900"
      = f.number_field :age, min: 1, max: 120, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:age].each do |msg|
        %p.text-lg.text-red-700= msg

    .space-y-2
      = f.label :height, "Height", class: "block text-xl font-medium text-gray-900"
      = f.text_field :height, placeholder: "e.g. 5'4\"", class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"
      - @bike_request.errors[:height].each do |msg|
        %p.text-lg.text-red-700= msg

    %hr.border-gray-200

    .space-y-2
      = f.label :notes, "Notes", class: "block text-xl font-medium text-gray-900"
      = f.text_area :notes, rows: 4, class: "w-full px-4 py-3 text-xl border-2 border-gray-400 focus:border-gray-900 focus:outline-none"

    .flex.gap-4
      = f.submit "Submit Request", class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors"
      = link_to "Cancel", distribution_center_path(@distribution_center), class: "px-6 py-3 text-lg font-medium text-gray-900 underline"
