:javascript
  function printBikeLabel(name, type, age, height, notes, requestor, phone, due) {
    var lines = [];
    if (name) lines.push('<p style="font-size:18pt;font-weight:bold;margin:0">' + name + '</p>');
    var detail = type;
    if (age) detail += ' &middot; Age ' + age;
    if (height) detail += ' &middot; ' + height;
    lines.push('<p style="font-size:14pt;margin:4px 0">' + detail + '</p>');
    if (notes) lines.push('<p style="font-size:12pt;margin:4px 0">' + notes + '</p>');
    lines.push('<p style="font-size:11pt;color:#555;margin:8px 0 0">' + requestor + ' &middot; ' + phone + '</p>');
    lines.push('<p style="font-size:11pt;color:#555;margin:2px 0">Due ' + due + '</p>');
    var win = window.open('', '_blank', 'width=400,height=300');
    win.document.write('<html><body style="font-family:sans-serif;padding:12px">' + lines.join('') + '<script>window.onload=function(){window.print();window.close();}<\/script></body></html>');
    win.document.close();
  }
  function printCard(bikes, requestor, phone, due) {
    var html = '';
    bikes.forEach(function(b) {
      var name = b[0], type = b[1], age = b[2], height = b[3], notes = b[4];
      html += '<div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid #ccc">';
      if (name) html += '<p style="font-size:18pt;font-weight:bold;margin:0">' + name + '</p>';
      var detail = type;
      if (age) detail += ' &middot; Age ' + age;
      if (height) detail += ' &middot; ' + height;
      html += '<p style="font-size:14pt;margin:4px 0">' + detail + '</p>';
      if (notes) html += '<p style="font-size:12pt;margin:4px 0">' + notes + '</p>';
      html += '<p style="font-size:11pt;color:#555;margin:8px 0 0">' + requestor + ' &middot; ' + phone + '</p>';
      html += '<p style="font-size:11pt;color:#555;margin:2px 0">Due ' + due + '</p>';
      html += '</div>';
    });
    var win = window.open('', '_blank', 'width=400,height=600');
    win.document.write('<html><body style="font-family:sans-serif;padding:12px">' + html + '<script>window.onload=function(){window.print();window.close();}<\/script></body></html>');
    win.document.close();
  }

- tabs = %w[requested completed delivered distributed]
.flex.border-b-2.border-gray-900.mb-8
  - tabs.each do |tab|
    = link_to url_for(tab: tab), class: "px-6 py-3 text-lg font-medium #{active_tab == tab ? 'font-bold border-b-4 border-gray-900 -mb-0.5' : 'text-gray-500'}" do
      = tab.capitalize
      %span.ml-1= "(#{tab_counts[tab] || 0})"

- if bike_requests.any?
  .space-y-4
    - bike_requests.each do |req|
      .border-2.border-gray-900.px-6.py-5.space-y-4
        .flex.items-start.justify-between.gap-4
          .space-y-1
            %p.text-2xl.font-bold.text-gray-900= req.requestor_name
            %p.text-lg.text-gray-600= req.phone
          .text-right.shrink-0.space-y-1
            %p.text-lg.font-medium.text-gray-900 Due #{req.due_date.strftime("%-m/%-d/%Y")}
            - unless production_view
              %p.text-lg.text-gray-500= req.distribution.name

        .overflow-x-auto
          %table.w-full.border-collapse
            %thead
              %tr.border-b-2.border-gray-200
                %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-700 Name
                %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-700 Type
                %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-700 Age
                %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-700 Height
                %th.text-left.px-3.py-2.text-lg.font-semibold.text-gray-700 Notes
                - if production_view
                  %th
                %th
            %tbody
              - req.bikes.each do |bike|
                %tr.border-b.border-gray-200
                  %td.px-3.py-2.text-lg.text-gray-900= bike.name.presence || "—"
                  %td.px-3.py-2.text-lg.text-gray-900= bike.bike_type.capitalize
                  %td.px-3.py-2.text-lg.text-gray-900= bike.age || "—"
                  %td.px-3.py-2.text-lg.text-gray-900= bike.height.presence || "—"
                  %td.px-3.py-2.text-lg.text-gray-900= bike.notes.presence || "—"
                  - if production_view
                    %td.px-3.py-2
                      - if bike.completed?
                        = button_to "Undo", bike_path(bike), method: :patch,
                            class: "px-3 py-1 text-lg font-medium text-gray-500 underline bg-transparent border-0 cursor-pointer"
                      - else
                        = button_to "Done", bike_path(bike), method: :patch,
                            class: "px-3 py-1 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors border-0"
                  %td.px-3.py-2
                    %button.px-3.py-1.text-lg.font-medium.text-gray-900.underline.bg-transparent.border-0.cursor-pointer{type: "button", onclick: "printBikeLabel(#{(bike.label_data + [req.requestor_name, req.phone, req.due_date.strftime('%-m/%-d/%Y')]).map(&:to_json).join(',')})"} Print

        - if production_view
          .flex.gap-4.mt-2
            - if req.completed?
              = button_to "Mark Delivered", bike_request_path(req), method: :patch, params: { status: "delivered" },
                  class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors border-0"
            - elsif req.delivered?
              = button_to "Mark Distributed", bike_request_path(req), method: :patch, params: { status: "distributed" },
                  class: "px-6 py-3 text-lg font-bold text-white bg-gray-900 hover:bg-gray-700 cursor-pointer transition-colors border-0"
              = button_to "Back to Completed", bike_request_path(req), method: :patch, params: { status: "completed" },
                  class: "px-4 py-2 text-lg font-medium text-gray-900 underline bg-transparent border-0 cursor-pointer"
            - elsif req.distributed?
              = button_to "Back to Delivered", bike_request_path(req), method: :patch, params: { status: "delivered" },
                  class: "px-4 py-2 text-lg font-medium text-gray-900 underline bg-transparent border-0 cursor-pointer"
            %button.text-lg.font-medium.text-gray-900.underline.bg-transparent.border-0.cursor-pointer.self-center{type: "button", onclick: "printCard(#{req.bikes_label_data.to_json}, #{req.requestor_name.to_json}, #{req.phone.to_json}, #{req.due_date.strftime('%-m/%-d/%Y').to_json})"} Print

  - if pagy.pages > 1
    .flex.items-center.gap-6.mt-8.text-lg
      - if pagy.prev
        = link_to "← Previous", url_for(tab: active_tab, page: pagy.prev), class: "text-gray-900 underline"
      %span.text-gray-500 Page #{pagy.page} of #{pagy.pages}
      - if pagy.next
        = link_to "Next →", url_for(tab: active_tab, page: pagy.next), class: "text-gray-900 underline"
- else
  %p.text-xl.text-gray-500 No #{active_tab} requests.
